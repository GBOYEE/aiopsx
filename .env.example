# AIOPS-X Environment

AIOPS_ENV=production
AIOPS_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg2://aiopsx:aiopsx@localhost:5432/aiopsx

# LLM Backends
OLLAMA_URL=http://localhost:11434
OPENAI_API_KEY=  # optional

# Monitoring
MONITOR_INTERVAL=60
CPU_THRESHOLD=85
MEMORY_THRESHOLD=90
DISK_THRESHOLD=90

# Approval workflow
APPROVAL_TIMEOUT=3600
ENABLE_APPROVALS=true

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# API authentication (set in production)
AIOPS_API_KEY=
# Role mappings (comma-separated usernames)
AIOPS_ADMIN_USERS=admin,superadmin
AIOPS_OPERATORS=operator1,operator2
